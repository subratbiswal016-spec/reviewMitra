{
  "manifest_version": 3,
  "name": "ReviewMitra AI",
  "version": "1.0.0",
  "description": "AI-powered Google Review replies for Indian businesses.",
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"],
      "css": ["jsx-runtime.css"]
    }
  ],
  "permissions": ["storage", "activeTab"]
}
